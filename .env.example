# Square API credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# Get your access token from: https://developer.squareup.com/apps
# Use a PRODUCTION token for live data, SANDBOX token for testing.
SQUARE_ACCESS_TOKEN=your_access_token_here

# Environment: "production" or "sandbox"
SQUARE_ENVIRONMENT=production

# Location ID to pull catalog/menu data for
# Find IDs by running: npm run list-locations
SQUARE_LOCATION_ID=your_location_id_here
